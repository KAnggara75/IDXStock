// Data get from IDX https://www.idx.co.id/en/market-data/trading-summary/stock-summary/
model History {
  id                    Int       @id @default(autoincrement())
  code                  String    @db.VarChar(200)
  date                  DateTime  @db.Date()
  previous              Int?
  open_price            Int?
  first_trade           Int?
  high                  Int?
  low                   Int?
  close                 Int?
  change                Int?
  volume                BigInt?
  value                 BigInt?
  frequency             BigInt?
  index_individual      Decimal?
  offer                 BigInt?
  offer_volume          BigInt?
  bid                   BigInt?
  bid_volume            BigInt?
  listed_shares         BigInt?
  tradeble_shares       BigInt?
  weight_for_index      BigInt?
  foreign_sell          BigInt?
  foreign_buy           BigInt?
  delisting_date        DateTime? @db.Date()
  non_regular_volume    BigInt?
  non_regular_value     BigInt?
  non_regular_frequency BigInt?
  insertBy              String    @db.VarChar(100)
  user                  User      @relation(fields: [insertBy], references: [username])
  stockCode             Stock     @relation(fields: [code], references: [code])

  @@map("history")
}
