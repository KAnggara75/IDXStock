// https://www.idx.co.id/en/market-data/stocks-data/stock-list/
model Stock {
  code         String    @id @db.VarChar(10)
  name         String    @unique @db.VarChar(200)
  listing_date DateTime? @db.Date()
  shares       BigInt
  board        Board     @default(Main)
  history      History[]

  @@index([code])
  @@map("stocks")
}

enum Board {
  Watchlist
  Main
  Development
  Acceleration
  EkonomiBaru
}
