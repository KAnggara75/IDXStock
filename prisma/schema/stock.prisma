model Stock {
  code      String   @id @db.VarChar(200)
  name      String   @unique @db.VarChar(200)
  price     Int?
  priceopen Int?
  high      Int?
  low       Int?
  volume    BigInt?
  marketcap BigInt?
  tradetime DateTime @default(now())
  volumeavg BigInt?
  pe        Decimal?
  eps       Decimal?
  high52    Int?
  low52     Int?
  change    Int?
  changepct Decimal?
  closeyest Int?
  shares    BigInt?

  @@map("stock")
}
